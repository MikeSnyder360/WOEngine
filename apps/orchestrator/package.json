{
  "name": "@woengine/orchestrator",
  "version": "0.1.0",
  "description": "Build orchestrator worker - generates, builds, and submits customer apps",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
