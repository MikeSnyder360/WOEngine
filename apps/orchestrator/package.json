  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.400.0",
    "@prisma/client": "^5.6.0",
    "@woengine/shared": "*",
    "bullmq": "^5.0.0",
    "execa": "^6.1.0",
    "pino": "^8.17.0",
    "simple-git": "^3.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^5.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
