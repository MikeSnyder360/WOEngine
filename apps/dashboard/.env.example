# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/woengine_dev"

# Stripe (optional - set PAYMENTS_DISABLED=true to skip charging in demo)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PAYMENTS_DISABLED="true"  # Set to "false" to enable real Stripe charging

# Auth (Next-Auth)
NEXTAUTH_SECRET="$(openssl rand -base64 32)"
NEXTAUTH_URL="http://localhost:3000"

# Clerk (optional, if using Clerk instead of NextAuth)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="..."
# CLERK_SECRET_KEY="..."

# App URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
